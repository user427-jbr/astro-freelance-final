---
import { languages, type Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileLinks from '../../components/ProfileLinks.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const isDE = lang === 'de';
---

<BaseLayout title={t('contact.title')} {lang} description={t('contact.intro')}>
  <div class="container page">

    <h1 class="page-title">{t('contact.title')}</h1>

    <div class="contact-layout">

      <!-- Left column: info -->
      <aside class="contact-info">
      </aside>

      <!-- Right column: form -->
      <form
        class="contact-form"
        name="contact"
        method="POST"
        data-netlify="true"
        novalidate
      >
        <div class="field">
          <label for="name">{t('contact.form.name')}</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder={t('contact.form.placeholder.name')}
            autocomplete="name"
            required
          />
        </div>

        <div class="field">
          <label for="email">{t('contact.form.email')}</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder={t('contact.form.placeholder.email')}
            autocomplete="email"
            required
          />
        </div>

        <div class="field">
          <label for="message">{t('contact.form.message')}</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder={t('contact.form.placeholder.message')}
            required
          ></textarea>
        </div>

        <div class="field privacy-field">
          <label class="privacy-label">
            <input type="checkbox" name="privacy" required />
            <span>
              {t('contact.form.privacy')}{' '}
              <a href={`/${lang}/datenschutz`}>{t('contact.form.privacy.link')}</a>{' '}
              {t('contact.form.privacy.suffix')}
            </span>
          </label>
        </div>
        <button type="submit" class="submit-btn">
          {t('contact.form.send')}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </form>

    </div>

  </div>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  @media (max-width: 760px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  /* Info column */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .contact-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.65;
  }

  .contact-direct {
    margin-top: calc(-1 * var(--space-sm));
  }

  .contact-email-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    width: 100%;
    transition: border-color var(--transition-base), color var(--transition-base);
  }
  .contact-email-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
  .contact-email-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .profiles-wrap {
    margin-top: calc(-1 * var(--space-sm));
  }

  .availability-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 3px solid var(--color-accent);
  }

  .avail-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 5px;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .avail-title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 4px;
  }

  .avail-detail {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .avail-hours {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 600;
    margin-top: 2px;
  }
</style>
