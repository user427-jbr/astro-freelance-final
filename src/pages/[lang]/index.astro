---
import { languages, type Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProfileLinks from '../../components/ProfileLinks.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FaqSection from '../../components/FaqSection.astro';
import { Icon } from 'astro-icon/components';
import { services as allServices } from '../../data/services';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const isDE = lang === 'de';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

const services = allServices.map((s) => ({
  slug: s.slug,
  icon: s.icon,
  name: isDE ? s.nameDE : s.nameEN,
  desc: isDE ? s.descDE : s.descEN,
  cardFeatures: isDE ? s.cardFeaturesDE : s.cardFeaturesEN,
  features: isDE ? s.featuresDE : s.featuresEN,
}));

const experience = isDE
  ? [
      { year: '2025 – heute', role: 'Werkstudent IT', place: 'VNG Gasspeicher GmbH, Leipzig', detail: 'MS Power Platform & Low Code Development' },
      { year: '2023 – 2024', role: 'Werkstudent', place: 'Abbott Rapid Diagnostics GmbH, Jena', detail: 'Power Apps, Power Automate' },
    ]
  : [
      { year: '2025 – present', role: 'Working Student IT', place: 'VNG Gasspeicher GmbH, Leipzig', detail: 'MS Power Platform & Low Code Development' },
      { year: '2023 – 2024', role: 'Working Student', place: 'Abbott Rapid Diagnostics GmbH, Jena', detail: 'Power Apps, Power Automate' },
    ];

const education = isDE
  ? [
      { year: '2025 – heute', role: 'Master Wirtschaftsinformatik', place: 'Universität Leipzig' },
      { year: '2020 – 2025', role: 'Bachelor Wirtschaftswissenschaften', place: 'Friedrich-Schiller-Universität Jena' },
    ]
  : [
      { year: '2025 – present', role: 'M.Sc. Business Informatics', place: 'University of Leipzig' },
      { year: '2020 – 2025', role: 'Bachelor Business Economics', place: 'Friedrich Schiller University Jena' },
    ];

const faq = isDE
  ? [
      { q: 'Wie läuft ein Projekt ab?', a: '1. Anforderungsanalyse – gemeinsames Erfassen aller Anforderungen. 2. Konzept & Planung – Lösungsarchitektur und Zeitplan. 3. Entwicklung & Test – iterative Umsetzung mit Ihrem Feedback. 4. Übergabe & Support – Dokumentation, Schulung und laufender Support.' },
      { q: 'Wie lange dauert ein typisches Projekt?', a: 'Je nach Komplexität kann ein typisches Projekt von wenigen Tagen für einfache automatisierte Workflows bis hin zu mehreren Wochen für umfassende Geschäftsanwendungen dauern.' },
      { q: 'Benötige ich spezielle Lizenzen?', a: 'Wenn Sie Standard-Konnektoren von Microsoft 365 (wie SharePoint und Outlook) verwenden, ist die Nutzung normalerweise in Ihrem bestehenden Plan enthalten. Premium-Konnektoren erfordern eigenständige Power Apps-Lizenzen.' },
      { q: 'Bieten Sie Unterstützung nach Projektabschluss an?', a: 'Ja! Ich biete fortlaufende Wartung, Fehlerbehebung und das Hinzufügen von Funktionen an, um sicherzustellen, dass Ihre Lösung weiterhin reibungslos läuft.' },
      { q: 'Was wird benötigt, um zu starten?', a: 'In der Regel benötige ich einen Gastzugang oder ein dediziertes Entwicklerkonto in Ihrem Microsoft 365 Tenant sowie entsprechende Lizenzen und Berechtigungen.' },
      { q: 'Wird ein Dienstkonto (Service Account) benötigt?', a: 'Ja, ein dediziertes Dienstkonto wird dringend empfohlen. Es fungiert als neutrales Konto für automatisierte Workflows und System-E-Mails.' },
    ]
  : [
      { q: 'How does a project work?', a: '1. Requirements analysis – capturing all requirements together. 2. Concept & planning – solution architecture and timeline. 3. Development & testing – iterative implementation with your feedback. 4. Handover & support – documentation, training, and ongoing support.' },
      { q: 'How long does a typical project take?', a: 'Depending on complexity, a project can take from a few days for simple automated workflows to several weeks for comprehensive business applications.' },
      { q: 'Do I need special licenses?', a: 'Standard Microsoft 365 connectors (like SharePoint and Outlook) are typically included in your existing plan. Premium connectors require standalone Power Apps licenses.' },
      { q: 'Do you offer post-project support?', a: 'Yes! I provide ongoing maintenance, troubleshooting, and feature additions to ensure your solution continues to run smoothly.' },
      { q: 'What is needed to start a project?', a: 'I typically need a guest account or dedicated developer account in your Microsoft 365 tenant, along with appropriate licenses and permissions.' },
      { q: 'Do I need a service account?', a: 'Yes, a dedicated service account is highly recommended for running automated workflows and sending system emails independently of individual users.' },
    ];
---

<BaseLayout title="Julius Bruch · Power Apps Freelancer Leipzig" {lang} description={t('hero.subtitle')}>

  <!-- Hero -->
  <Hero {lang} />

  <!-- About -->
  <section id="about" class="section">
    <div class="container">
      <SectionHeader icon="lucide:user-round" title={t('about.title')} />
      <div class="about-layout">
        <div class="about-text">
          <p class="about-intro">{t('about.intro')}</p>
          {t('about.body') && <blockquote class="about-mission">{t('about.body')}</blockquote>}
        </div>
        <aside class="about-aside">
          <div class="about-links-card">
            <div>
              <p class="panel-label">{t('projects.skills.title')}</p>
              <div class="skill-tags">
                {['Power Apps', 'Power Automate', 'SharePoint', 'Astro', 'HTML / CSS'].map(s => (
                  <span class="skill-tag">{s}</span>
                ))}
              </div>
            </div>
            <hr class="card-divider" />
            <div class="links-cols">
              <ProfileLinks label={t('about.profiles')} links={[
                { label: 'LinkedIn',     href: 'https://www.linkedin.com/in/julius-bruch' },
                { label: 'freelance.de', href: 'https://www.freelance.de' },
              ]} />
              <div class="profiles">
                <span class="profiles-label">{isDE ? 'Zertifikate' : 'Certifications'}</span>
                <a href="https://learn.microsoft.com/credentials/certifications/power-platform-app-maker/" rel="noopener noreferrer" target="_blank" class="profile-link">
                  PL-100
                  <Icon name="lucide:arrow-up-right" width="14" height="14" aria-hidden="true" />
                </a>
                <a href="https://learn.microsoft.com/credentials/certifications/power-platform-functional-consultant/" rel="noopener noreferrer" target="_blank" class="profile-link">
                  PL-200
                  <Icon name="lucide:arrow-up-right" width="14" height="14" aria-hidden="true" />
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="section">
    <div class="container">
      <SectionHeader icon="lucide:briefcase" title={t('services.title')} />
      <div class="svc-gallery">
        {services.map(({ slug, icon, name, desc, cardFeatures }) => (
          <a href={localizePath(`/${lang}/services/${slug}`)} class="svc-tile">
            <div class="svc-tile-icon">
              <Icon name={icon} width="22" height="22" aria-hidden="true" />
            </div>
            <p class="svc-tile-name">{name}</p>
            <p class="svc-tile-desc">{desc}</p>
            <div class="svc-tile-chips">
              {cardFeatures.map(f => <span class="svc-chip">{f}</span>)}
            </div>
            <Icon name="lucide:arrow-up-right" class="svc-tile-arrow" width="16" height="16" aria-hidden="true" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section">
    <div class="container">
      <SectionHeader icon="lucide:folder-open" title={t('projects.title')} />
      <div class="projects-layout">
        <div class="project-list">
          {projects.map((project, i) => (
            <ProjectCard
              title={isDE ? (project.data.titleDe ?? project.data.title) : (project.data.titleEn ?? project.data.title)}
              description={isDE ? (project.data.descDe ?? project.data.description) : (project.data.descEn ?? project.data.description)}
              techs={project.data.techs}
              slug={project.id}
              isLatest={i === 0}
              {lang}
            />
          ))}
        </div>

        <div class="newsletter-card">
          <div class="newsletter-body">
            <p class="newsletter-title">{t('newsletter.title')}</p>
            <p class="newsletter-sub">{t('newsletter.subtitle')}</p>
          </div>
          <form class="newsletter-form" name="newsletter" method="POST" data-netlify="true">
            <input
              type="email"
              name="email"
              placeholder={t('newsletter.placeholder')}
              required
              class="newsletter-input"
              autocomplete="email"
            />
            <button type="submit" class="newsletter-btn">
              {t('newsletter.cta')}
              <Icon name="lucide:arrow-right" width="14" height="14" aria-hidden="true" />
            </button>
          </form>
          <p class="newsletter-note">{t('newsletter.note')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <div class="container">
      <SectionHeader icon="lucide:mail" title={t('contact.title')} />

      <div class="contact-meta">
        <div class="avail-badge">
          <span class="avail-dot"></span>
          {t('contact.available')}
        </div>
        <div class="reach-item">
          <Icon name="lucide:clock" width="14" height="14" aria-hidden="true" />
          <span>{t('contact.response')}</span>
        </div>
      </div>

      <form class="contact-form" name="contact" method="POST" data-netlify="true">
        <div class="form-row">
          <div class="field">
            <label for="name">{t('contact.form.name')}</label>
            <input type="text" id="name" name="name" placeholder={t('contact.form.placeholder.name')} autocomplete="name" required />
          </div>
          <div class="field">
            <label for="email">{t('contact.form.email')}</label>
            <input type="email" id="email" name="email" placeholder={t('contact.form.placeholder.email')} autocomplete="email" required />
          </div>
        </div>
        <div class="field">
          <label for="message">{t('contact.form.message')}</label>
          <textarea id="message" name="message" rows="5" placeholder={t('contact.form.placeholder.message')} required></textarea>
        </div>
        <div class="form-footer">
          <label class="privacy-label">
            <input type="checkbox" name="privacy" required />
            <span>
              {t('contact.form.privacy')}{' '}
              <a href={localizePath(`/${lang}/datenschutz`)}>{t('contact.form.privacy.link')}</a>{' '}
              {t('contact.form.privacy.suffix')}
            </span>
          </label>
          <button type="submit" class="submit-btn">
            {t('contact.form.send')}
            <Icon name="lucide:send" width="16" height="16" aria-hidden="true" />
          </button>
        </div>
      </form>

    </div>
    <hr class="full-divider" />
    <div class="container" id="faq">
      <FaqSection title={t('contact.faq.title')} items={faq} idPrefix="home-faq" />
    </div>
  </section>


</BaseLayout>

<style>
  .section {
    padding-block: var(--space-2xl);
    scroll-margin-top: 70px;
    position: relative;
  }

  .section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-border);
  }

  #faq {
    scroll-margin-top: 70px;
  }

  /* About */
  .about-layout {
    display: grid;
    grid-template-columns: minmax(0, 560px) 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  @media (max-width: 760px) {
    .about-layout { grid-template-columns: 1fr; }
  }

  .about-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-links-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .links-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .card-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  .about-links-card :global(.profiles) {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .about-links-card :global(.profiles-label) {
    margin-bottom: 0;
  }

  .about-text {
    display: flex;
    flex-direction: column;
  }

  .about-intro {
    font-size: var(--text-lg);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .about-mission {
    margin: 0;
    margin-top: auto;
    padding: var(--space-md) var(--space-lg);
    border-left: 3px solid var(--color-accent);
    background-color: var(--color-accent-dim);
    border-radius: 0 8px 8px 0;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.75;
  }

  /* Projects + Newsletter side-by-side layout */
  .projects-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    align-items: start;
  }

  @media (max-width: 860px) {
    .projects-layout {
      grid-template-columns: 1fr;
    }
  }

  /* Newsletter */
  .newsletter-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .newsletter-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .newsletter-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-heading);
  }

  .newsletter-sub {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
    margin-top: var(--space-xs);
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .newsletter-input {
    flex: 1;
    min-width: 180px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 10px var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition-base);
  }
  .newsletter-input::placeholder { color: var(--color-muted); }
  .newsletter-input:focus { border-color: var(--color-accent); }

  .newsletter-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: 8px;
    padding: 10px var(--space-lg);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity var(--transition-base);
  }
  .newsletter-btn:hover { opacity: 0.85; }

  .newsletter-note {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* Services gallery */
  .svc-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
    gap: var(--space-md);
  }

  .svc-tile {
    position: relative;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .svc-tile::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, var(--color-accent-dim) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .svc-tile:hover { border-color: var(--color-accent); transform: translateY(-2px); text-decoration: none; }
  .svc-tile:hover::before { opacity: 1; }


  .svc-tile-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .svc-tile-name {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-heading);
  }

  .svc-tile-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
    flex: 1;
  }

  .svc-tile-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: auto;
  }

  .svc-chip {
    font-size: var(--text-sm);
    color: var(--color-muted);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 8px;
  }

  .svc-tile-arrow {
    position: absolute;
    top: var(--space-xl);
    right: var(--space-xl);
    color: var(--color-muted);
    transition: color var(--transition-base), transform var(--transition-base);
  }

  .svc-tile:hover .svc-tile-arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }


  /* Full-width divider */
  .full-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  .panel-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .skill-tag {
    font-size: var(--text-sm);
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    border-radius: 6px;
    padding: 4px 10px;
  }

  /* Contact meta strip */
  .contact-meta {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .avail-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
    border-radius: 999px;
    padding: 6px 14px;
    align-self: flex-start;
  }

  .avail-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  .reach-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .reach-item svg { flex-shrink: 0; color: var(--color-muted); }

  .reach-item a {
    color: var(--color-text);
    text-decoration: none;
  }
  .reach-item a:hover { color: var(--color-accent); }

</style>
