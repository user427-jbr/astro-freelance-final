---
import { languages, type Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProfileLinks from '../../components/ProfileLinks.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FaqSection from '../../components/FaqSection.astro';
import { Icon } from 'astro-icon/components';
import { services as allServices } from '../../data/services';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const isDE = lang === 'de';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

const services = allServices.map((s) => ({
  slug: s.slug,
  icon: s.icon,
  name: isDE ? s.nameDE : s.nameEN,
  desc: isDE ? s.descDE : s.descEN,
  features: isDE ? s.cardFeaturesDE : s.cardFeaturesEN,
}));

const experience = isDE
  ? [
      { year: '2025 – heute', role: 'Werkstudent IT', place: 'VNG Gasspeicher GmbH, Leipzig', detail: 'MS Power Platform & Low Code Development' },
      { year: '2023 – 2024', role: 'Werkstudent', place: 'Abbott Rapid Diagnostics GmbH, Jena', detail: 'Power Apps, Power Automate' },
    ]
  : [
      { year: '2025 – present', role: 'Working Student IT', place: 'VNG Gasspeicher GmbH, Leipzig', detail: 'MS Power Platform & Low Code Development' },
      { year: '2023 – 2024', role: 'Working Student', place: 'Abbott Rapid Diagnostics GmbH, Jena', detail: 'Power Apps, Power Automate' },
    ];

const education = isDE
  ? [
      { year: '2025 – heute', role: 'Master Wirtschaftsinformatik', place: 'Universität Leipzig' },
      { year: '2020 – 2025', role: 'Bachelor Wirtschaftswissenschaften', place: 'Friedrich-Schiller-Universität Jena' },
    ]
  : [
      { year: '2025 – present', role: 'M.Sc. Business Informatics', place: 'University of Leipzig' },
      { year: '2020 – 2025', role: 'Bachelor Business Economics', place: 'Friedrich Schiller University Jena' },
    ];

const faq = isDE
  ? [
      { q: 'Wie lange dauert ein typisches Projekt?', a: 'Je nach Komplexität kann ein typisches Projekt von wenigen Tagen für einfache automatisierte Workflows bis hin zu mehreren Wochen für umfassende Geschäftsanwendungen dauern.' },
      { q: 'Benötige ich spezielle Lizenzen?', a: 'Wenn Sie Standard-Konnektoren von Microsoft 365 (wie SharePoint und Outlook) verwenden, ist die Nutzung normalerweise in Ihrem bestehenden Plan enthalten. Premium-Konnektoren erfordern eigenständige Power Apps-Lizenzen.' },
      { q: 'Bieten Sie Unterstützung nach Projektabschluss an?', a: 'Ja! Ich biete fortlaufende Wartung, Fehlerbehebung und das Hinzufügen von Funktionen an, um sicherzustellen, dass Ihre Lösung weiterhin reibungslos läuft.' },
      { q: 'Was wird benötigt, um zu starten?', a: 'In der Regel benötige ich einen Gastzugang oder ein dediziertes Entwicklerkonto in Ihrem Microsoft 365 Tenant sowie entsprechende Lizenzen und Berechtigungen.' },
      { q: 'Wird ein Dienstkonto (Service Account) benötigt?', a: 'Ja, ein dediziertes Dienstkonto wird dringend empfohlen. Es fungiert als neutrales Konto für automatisierte Workflows und System-E-Mails.' },
    ]
  : [
      { q: 'How long does a typical project take?', a: 'Depending on complexity, a project can take from a few days for simple automated workflows to several weeks for comprehensive business applications.' },
      { q: 'Do I need special licenses?', a: 'Standard Microsoft 365 connectors (like SharePoint and Outlook) are typically included in your existing plan. Premium connectors require standalone Power Apps licenses.' },
      { q: 'Do you offer post-project support?', a: 'Yes! I provide ongoing maintenance, troubleshooting, and feature additions to ensure your solution continues to run smoothly.' },
      { q: 'What is needed to start a project?', a: 'I typically need a guest account or dedicated developer account in your Microsoft 365 tenant, along with appropriate licenses and permissions.' },
      { q: 'Do I need a service account?', a: 'Yes, a dedicated service account is highly recommended for running automated workflows and sending system emails independently of individual users.' },
    ];
---

<BaseLayout title={t('hero.headline')} {lang} description={t('hero.subtitle')}>

  <!-- Hero -->
  <Hero {lang} />

  <!-- About -->
  <section id="about" class="section">
    <div class="container">
      <SectionHeader icon="lucide:user-round" title={t('about.title')} subtitle={isDE ? 'Digital Transformation Consultant · Leipzig, DE' : 'Digital Transformation Consultant · Leipzig, DE'} />
      <div class="about-text">
        <p class="about-intro">{t('about.intro')}</p>
        <p class="about-body">{t('about.body')}</p>
        <div class="about-profiles">
          <ProfileLinks label={t('about.profiles')} links={[
            { label: 'LinkedIn',     href: 'https://www.linkedin.com/in/julius-bruch' },
            { label: 'freelance.de', href: 'https://www.freelance.de' },
          ]} />
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="section">
    <div class="container">
      <SectionHeader icon="lucide:briefcase" title={t('services.title')} subtitle={t('services.subtitle')} />
      <div class="service-grid">
        {services.map(({ slug, icon, name, desc, features }) => (
          <a href={localizePath(`/${lang}/services/${slug}`)} class="service-card">
            <div class="svc-card-top">
              <div class="service-icon"><Icon name={icon} width="26" height="26" aria-hidden="true" /></div>
              <Icon name="lucide:arrow-up-right" class="svc-arrow" width="16" height="16" aria-hidden="true" />
            </div>
            <p class="service-name">{name}</p>
            <ul class="svc-features">
              {features.map((f) => (
                <li>
                  <Icon name="lucide:check" width="12" height="12" aria-hidden="true" />
                  {f}
                </li>
              ))}
            </ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section">
    <div class="container">
      <SectionHeader icon="lucide:folder-open" title={t('projects.title')} subtitle={t('projects.subtitle')} />
      <div class="project-list">
        {projects.map((project, i) => (
          <ProjectCard
            title={isDE ? (project.data.titleDe ?? project.data.title) : (project.data.titleEn ?? project.data.title)}
            description={isDE ? (project.data.descDe ?? project.data.description) : (project.data.descEn ?? project.data.description)}
            techs={project.data.techs}
            slug={project.id}
            icon={project.data.icon}
            date={project.data.date}
            isLatest={i === 0}
            {lang}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <div class="container">
      <SectionHeader icon="lucide:mail" title={t('contact.title')} subtitle={t('contact.intro')} />

      <form class="contact-form" name="contact" method="POST" data-netlify="true" novalidate>
        <div class="form-row">
          <div class="field">
            <label for="name">{t('contact.form.name')}</label>
            <input type="text" id="name" name="name" placeholder={t('contact.form.placeholder.name')} autocomplete="name" required />
          </div>
          <div class="field">
            <label for="email">{t('contact.form.email')}</label>
            <input type="email" id="email" name="email" placeholder={t('contact.form.placeholder.email')} autocomplete="email" required />
          </div>
        </div>
        <div class="field">
          <label for="message">{t('contact.form.message')}</label>
          <textarea id="message" name="message" rows="5" placeholder={t('contact.form.placeholder.message')} required></textarea>
        </div>
        <div class="form-footer">
          <label class="privacy-label">
            <input type="checkbox" name="privacy" required />
            <span>
              {t('contact.form.privacy')}{' '}
              <a href={`/${lang}/datenschutz`}>{t('contact.form.privacy.link')}</a>{' '}
              {t('contact.form.privacy.suffix')}
            </span>
          </label>
          <button type="submit" class="submit-btn">
            {t('contact.form.send')}
            <Icon name="lucide:send" width="16" height="16" aria-hidden="true" />
          </button>
        </div>
      </form>

    </div>
    <hr class="full-divider" />
    <div class="container" id="faq">
      <FaqSection title={t('contact.faq.title')} subtitle={t('contact.faq.subtitle')} items={faq} idPrefix="home-faq" />
    </div>
  </section>


</BaseLayout>

<style>
  .section {
    padding-block: var(--space-3xl);
    scroll-margin-top: 70px;
    position: relative;
  }

  .section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-border);
  }

  #faq {
    scroll-margin-top: 70px;
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  @media (max-width: 760px) {
    .about-grid { grid-template-columns: 1fr; }
  }

  .about-photo-row {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .about-photo-placeholder {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 2px dashed var(--color-border);
    background-color: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border);
    flex-shrink: 0;
  }

  .about-role {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .about-intro {
    font-size: var(--text-lg);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .about-body {
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .tl-group { margin-bottom: var(--space-xl); }
  .tl-group:last-child { margin-bottom: 0; }

  .tl-group-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .tl-detail {
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  /* Services */
  .svc-features {
    list-style: none;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 6px 12px;
    margin-top: var(--space-sm);
  }

  .svc-features li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .svc-features svg { color: var(--color-accent); flex-shrink: 0; }

  /* Full-width divider */
  .full-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  /* Contact */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  @media (max-width: 760px) {
    .contact-layout { grid-template-columns: 1fr; }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .contact-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.65;
  }

  /* Newsletter */
  .newsletter-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .newsletter-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, var(--color-accent-dim) 0%, transparent 60%);
    pointer-events: none;
  }

  @media (max-width: 760px) {
    .newsletter-card { grid-template-columns: 1fr; }
  }

  .newsletter-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .newsletter-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
  }

  .newsletter-sub {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.65;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .newsletter-input-row {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background-color: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-sm) var(--space-md);
    outline: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .newsletter-input::placeholder { color: var(--color-muted); }

  .newsletter-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-dim);
  }

  .newsletter-note {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

</style>
