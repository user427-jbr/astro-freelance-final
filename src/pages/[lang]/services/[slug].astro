---
import { languages, type Lang } from '../../../i18n/ui';
import { useTranslations, localizePath } from '../../../i18n/utils';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageCta from '../../../components/PageCta.astro';
import { Icon } from 'astro-icon/components';
import { services } from '../../../data/services';

export function getStaticPaths() {
  return Object.keys(languages).flatMap((lang) =>
    services.map((service) => ({
      params: { lang, slug: service.slug },
      props: { service },
    }))
  );
}

const { lang } = Astro.params as { lang: Lang };
const { service } = Astro.props;
const t = useTranslations(lang);
const isDE = lang === 'de';

const name = isDE ? service.nameDE : service.nameEN;
const desc = isDE ? service.descDE : service.descEN;
const detail = isDE ? service.detailDE : service.detailEN;

---

<BaseLayout title={name} {lang} description={desc}>
  <div class="container page">

    <a href={localizePath(`/${lang}/#services`)} class="back-link">
      <Icon name="lucide:arrow-left" width="14" height="14" aria-hidden="true" />
      {isDE ? 'Zurück zu Leistungen' : 'Back to Services'}
    </a>

    <header class="service-detail-header">
      <div class="sdh-icon-row">
        <div class="sdh-icon" aria-hidden="true">
          <Icon name={service.icon} width="28" height="28" />
        </div>
      </div>
      <h1>{name}</h1>
      <p class="page-lead">{desc}</p>
    </header>

    <div class="sdh-body">
      <div class="sdh-detail">
        <p>{detail}</p>
      </div>
    </div>

    <PageCta
      heading={isDE ? 'Bereit für Ihr Projekt?' : 'Ready for your project?'}
      body={isDE ? 'Kontaktieren Sie mich für ein unverbindliches Angebot.' : 'Contact me for a no-obligation quote.'}
      ctaHref={localizePath(`/${lang}/#contact`)}
      ctaText={t('cta.contact')}
    />

  </div>
</BaseLayout>

<style>
  .service-detail-header {
    margin-bottom: var(--space-2xl);
  }

  .sdh-icon-row {
    margin-bottom: var(--space-lg);
  }

  .sdh-icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-detail-header h1 {
    margin-bottom: var(--space-sm);
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin-top: var(--space-sm);
  }

  .sdh-body {
    margin-bottom: var(--space-2xl);
    width: 100%;
  }

  .sdh-detail {
    width: 100%;
  }

  .sdh-detail p {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.75;
    max-width: none;
  }

</style>
