---
import { languages, type Lang } from '../../../i18n/ui';
import { useTranslations, localizePath } from '../../../i18n/utils';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageCta from '../../../components/PageCta.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { services } from '../../../data/services';

export function getStaticPaths() {
  return Object.keys(languages).flatMap((lang) =>
    services.map((service) => ({
      params: { lang, slug: service.slug },
      props: { service },
    }))
  );
}

const { lang } = Astro.params as { lang: Lang };
const { service } = Astro.props;
const t = useTranslations(lang);
const isDE = lang === 'de';

const name     = isDE ? service.nameDE     : service.nameEN;
const desc     = isDE ? service.descDE     : service.descEN;
const detail   = isDE ? service.detailDE   : service.detailEN;
const features = isDE ? service.featuresDE : service.featuresEN;
const useCases = isDE ? service.useCasesDE : service.useCasesEN;

const processSteps = isDE
  ? [t('services.process.1'), t('services.process.2'), t('services.process.3'), t('services.process.4')]
  : [t('services.process.1'), t('services.process.2'), t('services.process.3'), t('services.process.4')];
---

<BaseLayout title={name} {lang} description={desc}>
  <div class="container page">

    <PageHeader
      title={name}
      lead={desc}
      backHref={localizePath(`/${lang}/#services`)}
      backLabel={isDE ? 'Zurück zu Leistungen' : 'Back to Services'}
    />

    <!-- Body: detail text + feature card -->
    <div class="svc-body">
      <div class="svc-detail">
        <p>{detail}</p>

        <!-- Use cases -->
        <div class="svc-usecases">
          <p class="block-label">{isDE ? 'Typische Anwendungsfälle' : 'Typical use cases'}</p>
          <ul class="usecase-list">
            {useCases.map((uc) => (
              <li>
                <Icon name="lucide:chevron-right" width="14" height="14" aria-hidden="true" />
                <span>{uc}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Feature card -->
      <aside class="svc-features-card">
        <p class="block-label">{isDE ? 'Leistungsumfang' : 'What is included'}</p>
        <ul class="feature-list">
          {features.map((f) => (
            <li>
              <span class="feature-check" aria-hidden="true">
                <Icon name="lucide:check" width="13" height="13" />
              </span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>

    <!-- Process steps -->
    <section class="svc-process">
      <p class="block-label">{t('services.process.title')}</p>
      <ol class="process-steps">
        {processSteps.map((step, i) => (
          <li class="process-step">
            <span class="step-num">{i + 1}</span>
            <span class="step-label">{step}</span>
          </li>
        ))}
      </ol>
    </section>

    <PageCta
      heading={isDE ? 'Bereit für Ihr Projekt?' : 'Ready for your project?'}
      body={isDE ? 'Kontaktieren Sie mich für ein unverbindliches Erstgespräch.' : 'Get in touch for a no-obligation first call.'}
      ctaHref={localizePath(`/${lang}/#contact`)}
      ctaText={t('cta.contact')}
    />

  </div>
</BaseLayout>

<style>
  /* Body: two-column on desktop */
  .svc-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-2xl);
    align-items: start;
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 820px) {
    .svc-body { grid-template-columns: 1fr; }
    .svc-features-card { order: -1; }
  }

  /* Detail text */
  .svc-detail p {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.85;
    margin-bottom: var(--space-xl);
  }

  /* Use cases */
  .svc-usecases { margin-top: var(--space-lg); }

  .usecase-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .usecase-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.5;
  }

  .usecase-list li svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 3px;
  }

  /* Feature card */
  .svc-features-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-xl);
    position: sticky;
    top: 90px;
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .feature-check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Block label */
  .block-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Process steps */
  .svc-process {
    margin-bottom: var(--space-2xl);
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .process-steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-lg);
    counter-reset: steps;
  }

  @media (max-width: 640px) {
    .process-steps { grid-template-columns: 1fr 1fr; }
  }

  .process-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-label {
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }
</style>
