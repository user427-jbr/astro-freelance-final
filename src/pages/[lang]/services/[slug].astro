---
import { languages, type Lang } from '../../../i18n/ui';
import { useTranslations, localizePath } from '../../../i18n/utils';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageCta from '../../../components/PageCta.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { services } from '../../../data/services';

const serviceImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/*.{png,jpg,jpeg,webp,avif}'
);
export function getStaticPaths() {
  return Object.keys(languages).flatMap((lang) =>
    services.map((service) => ({
      params: { lang, slug: service.slug },
      props: { service },
    }))
  );
}

const { lang } = Astro.params as { lang: Lang };
const { service } = Astro.props;
const t = useTranslations(lang);
const isDE = lang === 'de';

const name     = isDE ? service.nameDE     : service.nameEN;
const desc     = isDE ? service.descDE     : service.descEN;
const detail   = isDE ? service.detailDE   : service.detailEN;
const imageKey = service.image ? `/src/assets/images/${service.image}` : null;
const resolvedImage = imageKey && serviceImages[imageKey] ? await serviceImages[imageKey]() : null;
const features = isDE ? service.featuresDE : service.featuresEN;
const useCases = isDE ? service.useCasesDE : service.useCasesEN;
---

<BaseLayout title={name} {lang} description={desc}>
  <div class="container page">

    <PageHeader
      title={name}
      icon={service.icon}
      backHref={localizePath(`/${lang}/#services`)}
      backLabel={t('back.services')}
    />

    <p class="svc-intro">{detail}</p>

    <div class="svc-image-placeholder">
      {resolvedImage
        ? <Image src={resolvedImage.default} alt={name} class="svc-image" />
        : <div class="svc-image-empty" aria-hidden="true">
            <Icon name="lucide:image" width="32" height="32" />
            <span>{isDE ? 'Bild folgt' : 'Image coming soon'}</span>
          </div>
      }
    </div>

    <!-- Features grid -->
    <section class="svc-section">
      <p class="block-label">{isDE ? 'Leistungsumfang' : 'What is included'}</p>
      <ul class="features-grid">
        {features.map((f) => (
          <li>
            <span class="feat-check" aria-hidden="true">
              <Icon name="lucide:check" width="13" height="13" />
            </span>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Use cases -->
    <section class="svc-section">
      <p class="block-label">{isDE ? 'Typische Anwendungsfälle' : 'Typical use cases'}</p>
      <ul class="usecase-chips">
        {useCases.map((uc) => (
          <li class="usecase-chip">
            <Icon name="lucide:chevron-right" width="13" height="13" aria-hidden="true" />
            {uc}
          </li>
        ))}
      </ul>
    </section>

    <PageCta
      heading={isDE ? 'Bereit für Ihr Projekt?' : 'Ready for your project?'}
      body={isDE ? 'Kontaktieren Sie mich für ein unverbindliches Erstgespräch.' : 'Get in touch for a no-obligation first call.'}
      ctaHref={localizePath(`/${lang}/#contact`)}
      ctaText={t('cta.contact')}
    />

  </div>
</BaseLayout>

<style>
  /* Tighten header spacing — no lead on this page */
  .page :global(.page-header) {
    padding-bottom: 0;
    margin-bottom: var(--space-lg);
  }
  .page :global(.page-header-title) {
    margin-bottom: 0;
    word-break: break-word;
    hyphens: auto;
  }

  .svc-intro {
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: 1.75;
    margin: 0 0 var(--space-xl);
  }

  .svc-image-placeholder {
    align-self: flex-start;
    margin-bottom: var(--space-xl);
  }

  .svc-image {
    width: 380px;
    height: auto;
    max-height: 300px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    display: block;
  }

  .svc-image-empty {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    border: 2px dashed var(--color-border);
    background-color: var(--color-surface);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .svc-section {
    margin-bottom: var(--space-xl);
  }

  .block-label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  /* Features 3-col grid */
  .features-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 760px) {
    .features-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  .features-grid li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .feat-check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Use case chips */
  .usecase-chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .usecase-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: var(--space-xs) var(--space-md);
  }

  .usecase-chip svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }
</style>
