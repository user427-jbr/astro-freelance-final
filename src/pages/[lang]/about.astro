---
import { languages, type Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProfileLinks from '../../components/ProfileLinks.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const profileLinks = [
  { label: 'LinkedIn',    href: 'https://www.linkedin.com/in/julius-bruch' },
  { label: 'freelance.de', href: 'https://www.freelance.de' },
];

const experience = lang === 'de'
  ? [
      {
        year: '2025 – heute',
        role: 'Werkstudent IT',
        place: 'VNG Gasspeicher GmbH, Leipzig',
        detail: 'MS Power Platform & Low-Code Development',
      },
      {
        year: '2023 – 2024',
        role: 'Werkstudent',
        place: 'Abbott Rapid Diagnostics GmbH, Jena',
        detail: 'Entwicklung interner Low-Code-Lösungen (Power Apps, Power Automate).',
      },
    ]
  : [
      {
        year: '2025 – present',
        role: 'Working Student IT',
        place: 'VNG Gasspeicher GmbH, Leipzig',
        detail: 'MS Power Platform & Low-Code Development',
      },
      {
        year: '2023 – 2024',
        role: 'Working Student',
        place: 'Abbott Rapid Diagnostics GmbH, Jena',
        detail: 'Development of internal low-code solutions (Power Apps, Power Automate).',
      },
    ];

const education = lang === 'de'
  ? [
      {
        year: '2025 – heute',
        role: 'Master Wirtschaftsinformatik',
        place: 'Universität Leipzig',
        detail: 'Master',
      },
      {
        year: '2020 – 2025',
        role: 'Bachelor',
        place: 'Friedrich-Schiller-Universität Jena',
        detail: 'Bachelor',
      },
    ]
  : [
      {
        year: '2025 – present',
        role: 'M.Sc. Business Informatics',
        place: 'University of Leipzig',
        detail: 'Master',
      },
      {
        year: '2020 – 2025',
        role: 'Bachelor',
        place: 'Friedrich Schiller University Jena',
        detail: 'Bachelor',
      },
    ];
---

<BaseLayout title={t('about.title')} {lang} description={t('about.intro')}>
  <div class="container page">

    <h1 class="page-title">{t('about.title')}</h1>

    <!-- Bio -->
    <div class="bio">
      <div class="bio-header">
        <div class="bio-avatar" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
        </div>
        <div>
          <p class="bio-role">{t('about.role')}</p>
          <p class="bio-location">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {t('about.location')}
          </p>
        </div>
      </div>
      <p class="bio-intro">{t('about.intro')}</p>
      <p>{t('about.body')}</p>
      <p class="availability">
        <span class="availability-dot" aria-hidden="true"></span>
        {t('about.availability')}
      </p>
    </div>

    <!-- Profile Links (second section) -->
    <div class="profile-section">
      <ProfileLinks label={t('about.profiles')} links={profileLinks} />
    </div>

    <!-- Experience Timeline -->
    <div class="timeline-section">
      <h2 class="section-heading">{t('about.exp')}</h2>
      <ol class="timeline" role="list">
        {experience.map(({ year, role, place, detail }) => (
          <li class="timeline-item">
            <span class="tl-year">{year}</span>
            <div class="tl-body">
              <strong class="tl-role">{role}</strong>
              <span class="tl-place">{place}</span>
              {detail && <span class="tl-detail">{detail}</span>}
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- Education Timeline -->
    <div class="timeline-section">
      <h2 class="section-heading">{lang === 'de' ? 'Bildungsweg' : 'Education'}</h2>
      <ol class="timeline" role="list">
        {education.map(({ year, role, place }) => (
          <li class="timeline-item">
            <span class="tl-year">{year}</span>
            <div class="tl-body">
              <strong class="tl-role">{role}</strong>
              <span class="tl-place">{place}</span>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- CTA -->
    <div class="page-cta">
      <div class="page-cta-text">
        <h3>{lang === 'de' ? 'Interesse geweckt?' : 'Interested?'}</h3>
        <p>{lang === 'de' ? 'Entdecken Sie meine Leistungen und Lösungen.' : 'Discover my services and solutions.'}</p>
      </div>
      <a href={localizePath(`/${lang}/services`)} class="btn-primary">
        {t('about.cta')}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2xl);
  }

  .bio-header {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .bio-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background-color: var(--color-surface);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border);
    flex-shrink: 0;
  }

  .bio-role {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 4px;
  }

  .bio-location {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .bio-intro {
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: 1.65;
  }

  .profile-section {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-section {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .tl-detail {
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
</style>
