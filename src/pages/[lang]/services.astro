---
import { languages, type Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const isDE = lang === 'de';

const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17.5h7M17.5 14v7"/></svg>`,
    name: t('services.powerapps'),
    desc: isDE
      ? 'Ich entwickle maßgeschneiderte Canvas- und modellgetriebene Apps für Ihre spezifischen Geschäftsanforderungen. Ob Formular-Digitalisierung, Genehmigungs-Workflows oder komplexe Datenverwaltung – ich liefere skalierbare Lösungen auf Basis von Microsoft 365.'
      : 'I develop custom Canvas and model-driven apps tailored to your specific business needs. Whether form digitization, approval workflows, or complex data management – I deliver scalable solutions built on Microsoft 365.',
    features: isDE
      ? ['Canvas Apps (Tablet & Mobil)', 'Modellgetriebene Apps', 'SharePoint & SQL Anbindung', 'Power Automate Integration', 'Responsive Design']
      : ['Canvas Apps (Tablet & Mobile)', 'Model-driven Apps', 'SharePoint & SQL integration', 'Power Automate integration', 'Responsive design'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l7-9 4 5 3-3 7 7"/><path d="M3 20h18"/></svg>`,
    name: t('services.automate'),
    desc: isDE
      ? 'Ich automatisiere Ihre Routineprozesse mit Power Automate: Genehmigungsflows, E-Mail-Benachrichtigungen, Datensynchronisation und vieles mehr. So sparen Sie Zeit und reduzieren manuelle Fehler.'
      : 'I automate your routine processes with Power Automate: approval flows, email notifications, data synchronization, and much more. Save time and reduce manual errors.',
    features: isDE
      ? ['Genehmigungsworkflows', 'Automatisierte E-Mails', 'Daten-Synchronisation', 'PDF-Generierung', 'Systemübergreifende Flows']
      : ['Approval workflows', 'Automated emails', 'Data synchronization', 'PDF generation', 'Cross-system flows'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>`,
    name: t('services.sharepoint'),
    desc: isDE
      ? 'Ich richte SharePoint-Intranetlösungen ein, die als Grundlage für Ihre Power Apps und Workflows dienen. Gut strukturierte Listen, Bibliotheken und Berechtigungskonzepte bilden das Fundament für alle Ihre digitalen Prozesse.'
      : 'I set up SharePoint intranet solutions that serve as the foundation for your Power Apps and workflows. Well-structured lists, libraries, and permission concepts form the backbone of all your digital processes.',
    features: isDE
      ? ['SharePoint Online Setup', 'Listen & Bibliotheken', 'Berechtigungskonzepte', 'Team Sites & Intranets', 'Dokumentenmanagement']
      : ['SharePoint Online setup', 'Lists & libraries', 'Permission management', 'Team sites & intranets', 'Document management'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    name: t('services.web'),
    desc: isDE
      ? 'Neben der Microsoft Power Platform entwickle ich auch professionelle Websites und Landing Pages für Unternehmen. Schnell, barrierefrei und modern – als perfekte digitale Visitenkarte für Ihr Unternehmen.'
      : 'In addition to the Microsoft Power Platform, I also develop professional websites and landing pages for businesses. Fast, accessible, and modern – the perfect digital business card.',
    features: isDE
      ? ['Statische Websites (Astro)', 'Responsive Design', 'SEO-Optimierung', 'Datenschutz-konform (DSGVO)', 'Schnelle Ladezeiten']
      : ['Static websites (Astro)', 'Responsive design', 'SEO optimization', 'GDPR-compliant', 'Fast load times'],
  },
];

const faq = isDE
  ? [
      { q: 'Wie lange dauert ein typisches Projekt?', a: 'Je nach Komplexität kann ein typisches Projekt von wenigen Tagen für einfache automatisierte Workflows bis hin zu mehreren Wochen für umfassende Geschäftsanwendungen mit mehreren Bildschirmen dauern.' },
      { q: 'Benötige ich spezielle Lizenzen?', a: 'Wenn Sie Standard-Konnektoren von Microsoft 365 (wie SharePoint und Outlook) verwenden, ist die Nutzung normalerweise in Ihrem bestehenden Plan enthalten. Premium-Konnektoren (wie SQL Server oder Salesforce) erfordern eigenständige Power Apps-Lizenzen.' },
      { q: 'Bieten Sie Unterstützung nach Projektabschluss an?', a: 'Ja! Ich biete fortlaufende Wartung, Fehlerbehebung und das Hinzufügen von Funktionen an, um sicherzustellen, dass Ihre Lösung weiterhin reibungslos läuft und sich an Ihre sich entwickelnden Geschäftsanforderungen anpasst.' },
      { q: 'Was wird benötigt, um zu starten?', a: 'Um Lösungen für Ihr Unternehmen zu entwickeln und bereitzustellen, benötige ich in der Regel einen Gastzugang oder ein dediziertes Entwicklerkonto in Ihrem Microsoft 365 Tenant. Je nach Projekt werden zudem entsprechende Lizenzen (z. B. Power Apps Premium) sowie Berechtigungen benötigt, um auf erforderliche Datenquellen zuzugreifen oder Umgebungen zu erstellen.' },
      { q: 'Wird ein Dienstkonto (Service Account) benötigt?', a: 'Ja, ein dediziertes Dienstkonto wird dringend empfohlen. Es fungiert als neutrales Konto für die Ausführung von automatisierten Workflows und den Versand von System-E-Mails, wodurch sichergestellt wird, dass die Prozesse unabhängig von einzelnen Benutzerkonten bleiben.' },
    ]
  : [
      { q: 'How long does a typical project take?', a: 'Depending on the complexity, a typical project can take anywhere from a few days for simple automated workflows to several weeks for comprehensive, multi-screen business applications.' },
      { q: 'Do I need special licenses?', a: 'If you use standard Microsoft 365 connectors (like SharePoint and Outlook), usage is typically included in your existing plan. Premium connectors (like SQL Server or Salesforce) require standalone Power Apps licenses.' },
      { q: 'Do you offer post-project support?', a: 'Yes! I provide ongoing maintenance, troubleshooting, and feature additions to ensure your solution continues to run smoothly and adapts to your evolving business needs.' },
      { q: 'What is needed to start a project?', a: 'To build and deploy solutions for your organization, I typically need a guest account or a dedicated developer account in your Microsoft 365 tenant. Depending on the project, appropriate licenses (e.g., Power Apps Premium) and permissions to access required data sources or create environments may also be necessary.' },
      { q: 'Do I need a service account?', a: 'Yes, a dedicated service account is highly recommended. It acts as a neutral account for running automated workflows and sending system emails, ensuring that processes remain independent of individual user accounts.' },
    ];
---

<BaseLayout title={t('services.title')} {lang} description={t('services.subtitle')}>
  <div class="container page">

    <h1 class="page-title">{t('services.title')}</h1>
    <p class="page-lead">{t('services.subtitle')}</p>

    <!-- Service Cards -->
    <div class="services-grid">
      {services.map(({ icon, name, desc, features }) => (
        <div class="service-detail-card">
          <div class="sdc-header">
            <div class="service-icon" set:html={icon}></div>
            <div>
              <h2 class="sdc-name">{name}</h2>
            </div>
          </div>
          <p class="sdc-desc">{desc}</p>
          <ul class="sdc-features">
            {features.map((f) => (
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2 class="section-heading">{t('contact.faq.title')}</h2>
      <ul class="faq-list" id="faq-list">
        {faq.map(({ q, a }, i) => (
          <li class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`faq-ans-${i}`}>
              {q}
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer" id={`faq-ans-${i}`}>{a}</div>
          </li>
        ))}
      </ul>
    </div>

    <!-- CTA -->
    <div class="page-cta">
      <div class="page-cta-text">
        <h3>{isDE ? 'Bereit für Ihr Projekt?' : 'Ready for your project?'}</h3>
        <p>{isDE ? 'Kontaktieren Sie mich für ein unverbindliches Angebot.' : 'Contact me for a no-obligation quote.'}</p>
      </div>
      <a href={localizePath(`/${lang}/contact`)} class="btn-primary">
        {t('cta.contact')}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</BaseLayout>

<script>
  function initFaq() {
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        if (!item) return;
        const isOpen = item.classList.contains('is-open');
        item.classList.toggle('is-open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  }
  initFaq();
  document.addEventListener('astro:after-swap', initFaq);
</script>

<style>
  .page-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin-bottom: var(--space-2xl);
    margin-top: calc(-1 * var(--space-lg));
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 28rem), 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .service-detail-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: border-color var(--transition-base);
  }
  .service-detail-card:hover { border-color: var(--color-accent); }

  .sdc-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .sdc-name {
    font-size: var(--text-xl);
    margin-bottom: 4px;
  }

  .sdc-price {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 600;
  }

  .sdc-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
  }

  .sdc-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: var(--space-xs);
  }

  .sdc-features li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .sdc-features svg { color: var(--color-accent); flex-shrink: 0; }

  .faq-section {
    margin-bottom: var(--space-2xl);
  }
</style>
