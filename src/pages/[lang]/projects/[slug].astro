---
import { languages, type Lang } from '../../../i18n/ui';
import { useTranslations, localizePath } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import PageCta from '../../../components/PageCta.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return Object.keys(languages).flatMap((lang) =>
    allProjects.map((project) => ({
      params: { lang, slug: project.id },
      props: { project },
    }))
  );
}

const { lang } = Astro.params as { lang: Lang };
const { project } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(project);

const title = lang === 'de' ? (project.data.titleDe ?? project.data.title) : (project.data.titleEn ?? project.data.title);
const description = lang === 'de' ? (project.data.descDe ?? project.data.description) : (project.data.descEn ?? project.data.description);
---

<PostLayout title={title} {lang} description={description}>
  <article>
    <a href={localizePath(`/${lang}/#projects`)} class="back-link">
      <Icon name="lucide:arrow-left" width="14" height="14" aria-hidden="true" />
      {t('back.projects')}
    </a>

    <header class="detail-header">
      <div class="detail-header-top">
        {project.data.icon && (
          <div class="detail-icon" aria-hidden="true">
            <Icon name={project.data.icon} width="28" height="28" />
          </div>
        )}
        {project.data.date && (
          <time class="detail-date">
            {project.data.date.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-US', { month: 'long', year: 'numeric' })}
          </time>
        )}
      </div>
      <h1>{title}</h1>
      <p class="detail-lead">{description}</p>

      {project.data.techs.length > 0 && (
        <ul class="tag-list" role="list">
          {project.data.techs.map((tech: string) => <li class="tag">{tech}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    <PageCta
      heading={lang === 'de' ? 'Interesse an einer ähnlichen Lösung?' : 'Interested in a similar solution?'}
      body={lang === 'de' ? 'Lassen Sie uns über Ihr Projekt sprechen.' : "Let's talk about your project."}
      ctaHref={localizePath(`/${lang}/#contact`)}
      ctaText={lang === 'de' ? 'Kontakt aufnehmen' : 'Get in touch'}
    />
  </article>
</PostLayout>

<style>
  .detail-header-top {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .detail-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .detail-date {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
</style>
