---
import { defaultLang } from '../i18n/ui';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const target = `${base}/${defaultLang}/`;
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
    <link rel="canonical" href={target} />
  </head>
  <body></body>
</html>
