---
interface Props {
  title: string;
  description: string;
  techs: string[];
  url?: string;
  slug: string;
  lang: string;
  icon?: string;
  date?: Date;
  isNew?: boolean;
  fadeDelay?: number;
}
import { localizePath, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import { Icon } from 'astro-icon/components';
const { title, description, url, slug, lang, icon, date, isNew = false, fadeDelay = 0 } = Astro.props;
const t = useTranslations(lang as Lang);
const detailHref = localizePath(`/${lang}/projects/${slug}`);
const dateLabel = date
  ? date.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { month: 'long', year: 'numeric' })
  : undefined;
---

<article class="project-card fade-in" data-fade-delay={fadeDelay}>
  <a href={detailHref} class="card-link">
    <div class="card-top">
      {icon && (
        <div class="card-icon">
          <Icon name={icon} width="20" height="20" aria-hidden="true" />
        </div>
      )}
      {isNew && <span class="card-badge">{t('projects.card.badge')}</span>}
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    {dateLabel && <div class="card-footer"><span class="card-date">{dateLabel}</span></div>}
  </a>

  {url && (
    <a href={url} target="_blank" rel="noopener noreferrer" class="card-external" aria-label="Open live project">
      <Icon name="lucide:external-link" width="14" height="14" aria-hidden="true" />
    </a>
  )}
</article>

<style>
  .project-card {
    position: relative;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    transition: border-color var(--transition-base);
    overflow: hidden;
  }

  .project-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .card-link:hover { text-decoration: none; }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xs);
  }

  .card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-title {
    font-size: var(--text-lg);
    color: var(--color-heading);
    font-weight: 700;
    line-height: 1.3;
    transition: color var(--transition-base);
  }
  .project-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
    flex: 1;
  }

  .card-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
    border-radius: 6px;
    padding: 2px 8px;
    line-height: 1.6;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .card-date {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-muted);
    margin-right: auto;
  }

  .card-external {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    display: inline-flex;
    align-items: center;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .card-external:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
