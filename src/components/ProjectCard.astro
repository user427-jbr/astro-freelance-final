---
interface Props {
  title: string;
  description: string;
  techs: string[];
  url?: string;
  slug: string;
  lang: string;
  icon?: string;
  date?: Date;
  isLatest?: boolean;
}
import { localizePath } from '../i18n/utils';
import { Icon } from 'astro-icon/components';
const { title, description, url, slug, lang, date, isLatest } = Astro.props;
const detailHref = localizePath(`/${lang}/projects/${slug}`);

const dateLabel = date
  ? date.toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-US', { month: 'long', year: 'numeric' })
  : null;
---

<article class:list={['project-entry', { 'is-latest': isLatest }]}>
  <a href={detailHref} class="entry-link">
    <div class="entry-body">
      <div class="entry-meta">
        {isLatest && <span class="badge">{lang === 'de' ? 'Neu' : 'New'}</span>}
        {dateLabel && <time class="entry-date">{dateLabel}</time>}
      </div>
      <h3 class="entry-title">{title}</h3>
      <p class="entry-desc">{description}</p>
    </div>

    <div class="entry-arrow" aria-hidden="true">
      <Icon name="lucide:arrow-right" width="16" height="16" />
    </div>
  </a>

  {url && (
    <a href={url} target="_blank" rel="noopener noreferrer" class="entry-external" aria-label="Open live project">
      <Icon name="lucide:arrow-up-right" width="14" height="14" aria-hidden="true" />
    </a>
  )}
</article>

<style>
  .project-entry {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }
  .project-entry:first-child {
    border-top: 1px solid var(--color-border);
  }

  .entry-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    text-decoration: none;
    color: inherit;
  }
  .entry-link:hover { text-decoration: none; }

  .entry-body {
    flex: 1;
    min-width: 0;
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .badge {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.03em;
  }

  .entry-date {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .entry-title {
    font-size: var(--text-lg);
    color: var(--color-heading);
    margin-bottom: var(--space-xs);
    transition: color var(--transition-base);
  }
  .project-entry:hover .entry-title {
    color: var(--color-accent);
  }

  .entry-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .entry-arrow {
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color var(--transition-base), transform var(--transition-base);
  }
  .project-entry:hover .entry-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  .entry-external {
    position: absolute;
    top: var(--space-lg);
    right: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .entry-external:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
