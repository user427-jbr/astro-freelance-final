---
interface Props {
  title: string;
  description: string;
  techs: string[];
  url?: string;
  slug: string;
  lang: string;
}
const { title, description, techs, url, slug, lang } = Astro.props;
const detailHref = `/${lang}/projects/${slug}`;
---

<article class="card">
  <a href={detailHref} class="card-link">
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    <ul class="card-techs" role="list">
      {techs.map((tech) => <li class="tech-tag">{tech}</li>)}
    </ul>
  </a>
  {url && (
    <a href={url} target="_blank" rel="noopener noreferrer" class="card-external" aria-label="Open project link">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10"/></svg>
    </a>
  )}
</article>

<style>
  .card {
    position: relative;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-lg);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link:hover {
    text-decoration: none;
  }

  .card-title {
    font-size: var(--text-xl);
    color: var(--color-heading);
    margin-bottom: var(--space-sm);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  .card-techs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
  }

  .tech-tag {
    font-size: var(--text-sm);
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    padding: 2px var(--space-sm);
    border-radius: 999px;
  }

  .card-external {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    text-decoration: none;
    line-height: 0;
    transition: color var(--transition-base);
  }

  .card-external:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
