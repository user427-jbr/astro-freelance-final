---
import { languages, type Lang } from '../i18n/ui';
import { BASE } from '../i18n/utils';

interface Props {
  lang: string;
}
const { lang } = Astro.props;

const langCodes  = Object.keys(languages);
const otherCode  = langCodes.find((code) => code !== lang) as Lang;

// Strip the deploy base, swap the language segment, re-add the base.
const rawPath    = Astro.url.pathname;
const noBase     = BASE && rawPath.startsWith(BASE) ? rawPath.slice(BASE.length) : rawPath;
const otherHref  = BASE + noBase.replace(/^\/[^/]+/, '/' + otherCode);
const otherLabel = 'Switch to ' + languages[otherCode];
---

<a
  id="lang-switch"
  href={otherHref}
  class="lang-btn"
  hreflang={otherCode}
  aria-label={otherLabel}
>
  {otherCode.toUpperCase()}
</a>

<script define:vars={{ langCodes, labels: languages, base: BASE }}>
  // The nav is persisted across navigations, so the build-time href goes stale.
  // Recompute the language link from the CURRENT path on every navigation,
  // accounting for the deploy base path.
  function syncLang() {
    const a = document.getElementById('lang-switch');
    if (!a) return;
    const raw = location.pathname;
    const noBase = base && raw.startsWith(base) ? raw.slice(base.length) : raw;
    const current = noBase.split('/')[1];
    const other = langCodes.find((code) => code !== current) || current;
    a.setAttribute('href', base + noBase.replace(/^\/[^/]+/, '/' + other));
    a.setAttribute('hreflang', other);
    a.setAttribute('aria-label', 'Switch to ' + labels[other]);
    a.textContent = other.toUpperCase();
  }

  syncLang();
  document.addEventListener('astro:after-swap', syncLang);
</script>

<style>
  .lang-btn {
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition-base);
    line-height: 1;
  }

  .lang-btn:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>
