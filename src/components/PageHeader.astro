---
interface Props {
  title: string;
  lead?: string;
  backHref: string;
  backLabel: string;
  icon?: string;
}
import { Icon } from 'astro-icon/components';
const { title, lead, backHref, backLabel, icon } = Astro.props;
---

<div class="page-header">
  <a href={backHref} class="back-link">
    <Icon name="lucide:arrow-left" width="14" height="14" aria-hidden="true" />
    {backLabel}
  </a>
  <h1 class="page-header-title">
    {icon && <span class="title-icon"><Icon name={icon} width="32" height="32" aria-hidden="true" /></span>}
    {title}
  </h1>
  {lead && <p class="page-header-lead">{lead}</p>}
  {Astro.slots.has('default') && (
    <div class="page-header-slot">
      <slot />
    </div>
  )}
</div>

<style>
  .page-header {
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
    position: relative;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: var(--space-xl);
    transition: color var(--transition-base);
  }
  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .page-header-title {
    font-size: var(--text-4xl);
    color: var(--color-heading);
    line-height: 1.15;
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .page-header-title {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .title-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .page-header-lead {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .page-header-slot {
    margin-top: var(--space-lg);
  }
</style>
