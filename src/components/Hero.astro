---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang as Lang);
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <p class="hero-tagline">{t('hero.tagline')}</p>
      <h1 class="headline">{t('hero.headline')}</h1>
      <p class="subtitle">{t('hero.subtitle')}</p>

      <div class="cta-group">
        <a href="#services" class="btn btn-primary">
          {t('hero.cta.more')}
          <Icon name="lucide:arrow-right" width="14" height="14" aria-hidden="true" />
        </a>
        <a href="#contact" class="btn btn-ghost">
          {t('hero.cta.contact')}
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <Icon name="mdi:laptop-account" width="180" height="180" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-2xl) calc(var(--space-2xl) * 1.5);
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .hero-visual {
    flex-shrink: 0;
    color: var(--color-accent);
    opacity: 0.18;
  }

  .hero-tagline {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .headline {
    font-size: var(--text-4xl);
    color: var(--color-heading);
    line-height: 1.15;
  }

  .subtitle {
    font-size: var(--text-base);
    color: var(--color-muted);
    margin-top: var(--space-md);
    line-height: 1.65;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-base);
    font-weight: 600;
    border-radius: 8px;
    padding: 12px var(--space-xl);
    text-decoration: none;
    transition: opacity var(--transition-base), transform var(--transition-base), border-color var(--transition-base), color var(--transition-base);
    white-space: nowrap;
  }
  .btn:hover { text-decoration: none; transform: translateY(-1px); }

  .btn-primary { color: #0a0a0a; background-color: var(--color-accent); }
  .btn-primary:hover { opacity: 0.88; }

  :global([data-theme="light"]) .btn-primary { color: #fff; }

  .btn-ghost {
    color: var(--color-text);
    background-color: transparent;
    border: 1px solid var(--color-muted);
  }
  .btn-ghost:hover { border-color: var(--color-heading); color: var(--color-heading); }

  @media (max-width: 480px) {
    .hero-visual { display: none; }
  }

  @media (max-width: 600px) {
    .cta-group { flex-direction: column; }
    .btn { width: 100%; justify-content: center; }
  }
</style>
