---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, localizePath, BASE } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang as Lang);

const home = localizePath(`/${lang}/`);
const navLinks = [
  { key: 'nav.about',    href: `${home}#about` },
  { key: 'nav.services', href: `${home}#services` },
  { key: 'nav.projects', href: `${home}#projects` },
  { key: 'nav.contact',  href: `${home}#contact` },
  { key: 'nav.faq',      href: `${home}#faq` },
] as const;
---

<nav id="main-nav" transition:persist>
  <div class="nav-inner container">

    <a href={localizePath(`/${lang}/`)} class="logo" aria-label="Julius Bruch — Home">
      <span class="logo-bracket">&lt;</span><span class="logo-mark">JB</span><span class="logo-bracket">/&gt;</span>
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map(({ key, href }) => (
        <li>
          <a href={href} class="nav-link">{t(key)}</a>
        </li>
      ))}
      <span class="nav-indicator" id="nav-indicator" aria-hidden="true"></span>
    </ul>

    <div class="nav-right">
      <span class="theme-wrap"><ThemeToggle lang={lang} /></span>
      <span class="divider" aria-hidden="true"></span>
      <LanguageSwitcher lang={lang} />
      <button
        id="hamburger"
        class="hamburger"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="17" viewBox="0 0 24 17" aria-hidden="true">
          <rect class="b1" y="0"  width="24" height="2.5" rx="1.25" fill="currentColor"/>
          <rect class="b2" y="7"  width="24" height="2.5" rx="1.25" fill="currentColor"/>
          <rect class="b3" y="14" width="24" height="2.5" rx="1.25" fill="currentColor"/>
        </svg>
      </button>
    </div>

  </div>
</nav>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <ul class="mobile-links" role="list">
    {navLinks.map(({ key, href }) => (
      <li>
        <a href={href} class="mobile-link">{t(key)}</a>
      </li>
    ))}
  </ul>
</div>

<script>
  function moveIndicator(activeLink) {
    const indicator = document.getElementById('nav-indicator');
    const list = document.querySelector('#main-nav .nav-links');
    if (!indicator || !list || !activeLink) { if (indicator) indicator.style.opacity = '0'; return; }
    const listRect = list.getBoundingClientRect();
    const linkRect = activeLink.getBoundingClientRect();
    indicator.style.opacity = '1';
    indicator.style.width  = linkRect.width + 'px';
    indicator.style.transform = `translateY(-50%) translateX(${linkRect.left - listRect.left}px)`;
  }

  function syncActive(id) {
    let active = null;
    document.querySelectorAll('#main-nav .nav-link, #mobile-menu .mobile-link').forEach((a) => {
      const hash = new URL(a.href, location.href).hash.slice(1);
      const matches = id === '' ? hash === '' : hash === id;
      if (matches) { a.setAttribute('aria-current', 'page'); if (a.classList.contains('nav-link')) active = a; }
      else a.removeAttribute('aria-current');
    });
    moveIndicator(active);
  }

  function initScrollSpy() {
    const sectionIds = ['about', 'services', 'projects', 'contact', 'faq'];
    const visible = new Map();

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        visible.set(e.target.id, e.isIntersecting ? e.intersectionRatio : 0);
      });
      // pick the section with the highest visible ratio; on ties prefer
      // the one that appears first in page order (top of list)
      let best = '';
      let bestRatio = 0;
      sectionIds.forEach((id) => {
        const r = visible.get(id) ?? 0;
        if (r > bestRatio) { bestRatio = r; best = id; }
      });
      syncActive(bestRatio > 0 ? best : '');
    }, {
      rootMargin: '-8% 0px -50% 0px',
      threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
    });

    sectionIds.forEach((id) => {
      const el = document.getElementById(id);
      if (el) io.observe(el);
    });

    return () => io.disconnect();
  }

  let cleanup = null;

  function initNav() {
    const hamburger = document.getElementById('hamburger');
    const menu      = document.getElementById('mobile-menu');
    const nav       = document.getElementById('main-nav');
    if (!hamburger || !menu || !nav) return;

    function syncTop() { menu.style.top = nav.offsetHeight + 'px'; }
    syncTop();
    new ResizeObserver(syncTop).observe(nav);

    function open() {
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.setAttribute('aria-label', 'Menü schließen');
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Menü öffnen');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    hamburger.addEventListener('click', () =>
      menu.classList.contains('is-open') ? close() : open()
    );
    menu.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', close));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  }

  syncActive('');
  if (cleanup) cleanup();
  cleanup = initScrollSpy();
  initNav();
  window.addEventListener('resize', () => {
    const active = document.querySelector('#main-nav .nav-link[aria-current="page"]');
    moveIndicator(active);
  });

  document.addEventListener('astro:after-swap', () => {
    const menu = document.getElementById('mobile-menu');
    const btn  = document.getElementById('hamburger');
    if (menu) { menu.classList.remove('is-open'); menu.setAttribute('aria-hidden', 'true'); }
    if (btn)  { btn.setAttribute('aria-expanded', 'false'); btn.setAttribute('aria-label', 'Menü öffnen'); }
    document.body.style.overflow = '';
    syncActive('');
    if (cleanup) cleanup();
    cleanup = initScrollSpy();
    initNav();
  });
</script>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background-color: color-mix(in srgb, var(--color-bg) 80%, transparent);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-block: 18px;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity var(--transition-base);
    font-variant-ligatures: none;
    font-feature-settings: "liga" 0, "calt" 0;
  }
  .logo:hover    { opacity: 0.7; text-decoration: none; }
  .logo-bracket  { color: var(--color-muted); }
  .logo-mark     { color: var(--color-accent); }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2px;
    flex: 1;
    justify-content: center;
    align-items: center;
  }

  .nav-link {
    position: relative;
    display: block;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    padding: 9px 16px;
    white-space: nowrap;
    transition: color 200ms ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 2px;
    left: 16px;
    right: 16px;
    background-color: var(--color-accent);
    transition: width 0.25s ease;
  }

  .nav-link:hover { color: var(--color-text); text-decoration: none; }
  .nav-link:hover::after { width: calc(100% - 32px); }

  .nav-link[aria-current="page"] { color: var(--color-accent); }
  .nav-link[aria-current="page"]::after { width: calc(100% - 32px); }

  /* Pill indicator hidden — replaced by underline */
  .nav-indicator { display: none; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-left: auto;
    flex-shrink: 0;
  }

  .theme-wrap { display: flex; align-items: center; }
  .divider { width: 1px; height: 20px; background-color: var(--color-border); }

  .hamburger {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--color-muted);
    line-height: 0;
    flex-shrink: 0;
    display: none;
    align-items: center;
    justify-content: center;
    transition: color var(--transition-base);
  }
  .hamburger:hover { color: var(--color-text); }
  .hamburger svg rect {
    transition: transform 280ms ease, opacity 180ms ease;
    transform-box: fill-box;
    transform-origin: center;
  }
  .hamburger[aria-expanded="true"] .b1 { transform: translateY(6px) rotate(45deg); }
  .hamburger[aria-expanded="true"] .b2 { opacity: 0; }
  .hamburger[aria-expanded="true"] .b3 { transform: translateY(-6px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-lg) clamp(1rem, 5vw, 2.5rem) var(--space-2xl);
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg);
    position: fixed;
    inset: 0;
    top: 57px;
    z-index: 190;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease;
  }
  .mobile-menu.is-open { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .mobile-links { list-style: none; }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-base);
  }
  .mobile-link:hover { color: var(--color-accent); text-decoration: none; }
  .mobile-link[aria-current="page"] { color: var(--color-accent); }
  .mobile-link[aria-current="page"]::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .nav-links   { display: none; }
    .hamburger   { display: flex; }
    .mobile-menu { display: flex; }
  }
</style>
