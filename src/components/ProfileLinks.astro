---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  label: string;
  links: LinkItem[];
}

const { label, links } = Astro.props;
---

<div class="profiles">
  <span class="profiles-label">{label}</span>
  {links.map(({ label: linkLabel, href }) => (
    <a href={href} rel="noopener noreferrer" target="_blank" class="profile-link">
      {linkLabel}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10"/></svg>
    </a>
  ))}
</div>
