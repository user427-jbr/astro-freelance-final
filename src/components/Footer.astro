---
import { useTranslations, localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang as Lang);
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <p class="copy">&copy; {year} Julius Bruch. {lang === 'de' ? 'Alle Rechte vorbehalten.' : 'All rights reserved.'}</p>
    <ul class="footer-links" role="list">
      <li>
        <a href={localizePath(`/${lang}/impressum`)}>{t('footer.impressum')}</a>
      </li>
      <li>
        <a href={localizePath(`/${lang}/datenschutz`)}>{t('footer.privacy')}</a>
      </li>
    </ul>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding-block: var(--space-xl);
  }

  .footer-links {
    justify-self: end;
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
      justify-items: start;
      gap: var(--space-sm);
    }
    .footer-links {
      justify-self: start;
    }
  }

  .copy {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .footer-links {
    display: flex;
    list-style: none;
    gap: var(--space-md);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--color-muted);
    transition: color var(--transition-base);
  }

  .footer-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

</style>
