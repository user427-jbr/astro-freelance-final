---
import { Icon } from 'astro-icon/components';

interface Props {
  heading: string;
  body: string;
  ctaHref: string;
  ctaText: string;
}

const { heading, body, ctaHref, ctaText } = Astro.props;
---

<div class="page-cta">
  <div class="page-cta-text">
    <h3>{heading}</h3>
    <p>{body}</p>
  </div>
  <a href={ctaHref} class="btn-primary">
    {ctaText}
    <Icon name="lucide:arrow-right" width="14" height="14" aria-hidden="true" />
  </a>
</div>
