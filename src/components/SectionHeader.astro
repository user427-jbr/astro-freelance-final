---
interface Props {
  title: string;
  subtitle?: string;
  headingLevel?: 'h2' | 'h3';
}

const { title, subtitle, headingLevel = 'h2' } = Astro.props;
const HeadingTag = headingLevel;
---

<div class="section-header fade-in">
  <HeadingTag class="section-title">{title}</HeadingTag>
</div>
{subtitle && <p class="section-sub">{subtitle}</p>}
