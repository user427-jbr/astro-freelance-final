---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang as Lang);
---

<button class="theme-toggle-btn" aria-label={t('theme.toggle')} title={t('theme.toggle')}>
  <span class="icon icon-sun" aria-hidden="true"><Icon name="lucide:sun" width="16" height="16" /></span>
  <span class="icon icon-moon" aria-hidden="true"><Icon name="lucide:moon" width="16" height="16" /></span>
</button>

<script>
  function initToggles() {
    document.querySelectorAll('.theme-toggle-btn').forEach((el) => {
      const btn = el as HTMLElement;
      // The button lives in the persisted nav, so its listener survives
      // navigation. Guard against binding it again on each swap (duplicate
      // listeners would toggle the theme multiple times per click).
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (_) {}
      });
    });
  }
  initToggles();
  document.addEventListener('astro:after-swap', initToggles);
</script>

<style>
  button {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 2px;
    cursor: pointer;
    color: var(--color-muted);
    line-height: 0;
    transition: color var(--transition-base);
    flex-shrink: 0;
  }

  button:hover {
    color: var(--color-text);
  }

  .icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
  }

  /* dark mode: show sun, hide moon */
  :global(:not([data-theme="light"])) .icon-sun  { display: block; }
  :global(:not([data-theme="light"])) .icon-moon { display: none; }

  /* light mode: show moon, hide sun */
  :global([data-theme="light"]) .icon-sun  { display: none; }
  :global([data-theme="light"]) .icon-moon { display: block; }
</style>
