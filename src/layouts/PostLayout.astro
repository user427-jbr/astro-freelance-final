---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  lang: string;
  description: string;
  ogImage?: string;
}

const { title, lang, description, ogImage } = Astro.props;
---

<BaseLayout {title} {lang} {description} {ogImage}>
  <div class="post-container">
    <slot />
  </div>
</BaseLayout>

<style>
  .post-container {
    width: 100%;
    max-width: 65ch;
    margin-inline: auto;
    padding-inline: clamp(1rem, 5vw, 2.5rem);
    padding-block: var(--space-2xl);
  }
</style>
